  <palette_color_bias>

    <palette id="lower_grade_core">
      <color_bias>整体色调可轻微偏向明亮天空蓝与柔和暖黄，保持高明度与轻快感</color_bias>
    </palette>

    <palette id="writing_warm_brown">
      <color_bias>整体色调可轻微偏向米色与温暖棕色，降低饱和度，呈现纸张质感</color_bias>
    </palette>

    <palette id="playful_coral">
      <color_bias>整体色调可轻微偏向珊瑚粉与浅蓝，对比柔和但保持活泼感</color_bias>
    </palette>

    <palette id="forest_green">
      <color_bias>整体色调可轻微偏向清新绿色，明度适中，避免过深或过暗</color_bias>
    </palette>

    <palette id="pond_blue">
      <color_bias>整体色调可轻微偏向清透蓝色与浅青绿，增加通透感与轻盈感</color_bias>
    </palette>

    <palette id="autumn_ochre">
      <color_bias>整体色调可轻微偏向暖赭色与柔和金色，营造温暖但不过重的色彩氛围</color_bias>
    </palette>

    <palette id="winter_cool_blue">
      <color_bias>整体色调可轻微偏向低饱和冷蓝与浅灰蓝，保持清淡与安静</color_bias>
    </palette>

    <palette id="dreamy_purple_blue">
      <color_bias>整体色调可轻微偏向紫蓝色与淡紫光感，饱和度适中偏柔和</color_bias>
    </palette>

    <palette id="fable_red_brown">
      <color_bias>整体色调可轻微偏向红棕与米色，色彩温和不过分鲜艳</color_bias>
    </palette>

    <palette id="classical_qingdai">
      <color_bias>整体色调可轻微偏向青黛灰绿，降低对比度，保持克制与留白感</color_bias>
    </palette>

    <palette id="bamboo_ink_green">
      <color_bias>整体色调可轻微偏向墨绿与灰绿，饱和度偏低，呈现沉静气质</color_bias>
    </palette>

    <palette id="vermilion_gold">
      <color_bias>整体色调可轻微偏向朱红与米金，红色控制在点缀级别不过度铺满</color_bias>
    </palette>

    <palette id="literary_blue_gray">
      <color_bias>整体色调可轻微偏向蓝灰与中性色，降低饱和度以提升阅读舒适度</color_bias>
    </palette>

    <palette id="homeland_red_blue">
      <color_bias>整体色调可轻微偏向深红与沉稳蓝，控制对比，保持庄重感</color_bias>
    </palette>

    <palette id="knowledge_blue_green">
      <color_bias>整体色调可轻微偏向蓝绿与白色，保持清晰、干净与结构感</color_bias>
    </palette>

    <palette id="math_blue_orange">
      <color_bias>整体色调可轻微偏向清爽蓝色，辅以少量橙色强调重点</color_bias>
    </palette>

    <palette id="math_deep_blue">
      <color_bias>整体色调可轻微偏向深蓝与灰色，增强理性与结构感，避免高饱和</color_bias>
    </palette>

    <palette id="physics_dark_teal">
      <color_bias>整体色调可轻微偏向冷青色与深蓝，辅以少量亮色点缀增强科技感</color_bias>
    </palette>

    <palette id="default_yuwen_balanced">
      <color_bias>整体色调保持中性平衡，可略微偏向浅蓝与柔和暖色，避免明显色彩倾向</color_bias>
    </palette>

  </palette_color_bias>

</visual>

  <palette_routing>

    <rule priority="110">
      <match_terms>池塘,荷塘,湖水,小蝌蚪,青蛙,倒影</match_terms>
      <apply_palette>pond_blue</apply_palette>
    </rule>

    <rule priority="105">
      <match_terms>雪,冰雪,冬天,梅花</match_terms>
      <apply_palette>winter_cool_blue</apply_palette>
    </rule>

    <rule priority="104">
      <match_terms>秋天,落叶,丰收</match_terms>
      <apply_palette>autumn_ochre</apply_palette>
    </rule>

    <rule priority="100">
      <match_terms>古诗,诗词</match_terms>
      <apply_palette>classical_qingdai</apply_palette>
    </rule>

    <rule priority="99">
      <match_terms>文言文,古文</match_terms>
      <apply_palette>bamboo_ink_green</apply_palette>
    </rule>

    <rule priority="98">
      <match_terms>节日,春节,中秋</match_terms>
      <apply_palette>vermilion_gold</apply_palette>
    </rule>

    <rule priority="96">
      <match_terms>童话,神话</match_terms>
      <apply_palette>dreamy_purple_blue</apply_palette>
    </rule>

    <rule priority="95">
      <match_terms>寓言,道理</match_terms>
      <apply_palette>fable_red_brown</apply_palette>
    </rule>

    <rule priority="94">
      <match_terms>动物,植物,森林</match_terms>
      <apply_palette>forest_green</apply_palette>
    </rule>

    <rule priority="93">
      <match_terms>说明文,科普</match_terms>
      <apply_palette>knowledge_blue_green</apply_palette>
    </rule>

    <rule priority="92">
      <match_terms>写人,记事,散文</match_terms>
      <apply_palette>literary_blue_gray</apply_palette>
    </rule>

    <rule priority="92">
      <match_terms>物理,力,运动,电,光</match_terms>
      <apply_palette>physics_dark_teal</apply_palette>
    </rule>

    <rule priority="91">
      <match_terms>爱国,英雄</match_terms>
      <apply_palette>homeland_red_blue</apply_palette>
    </rule>

    <rule priority="90">
      <match_terms>加减乘除,分数,应用题</match_terms>
      <apply_palette>math_blue_orange</apply_palette>
    </rule>

    <rule priority="89">
      <match_terms>方程,函数,几何</match_terms>
      <apply_palette>math_deep_blue</apply_palette>
    </rule>

    <rule priority="80">
      <match_terms>拼音,识字,生字</match_terms>
      <apply_palette>lower_grade_core</apply_palette>
    </rule>

    <rule priority="79">
      <match_terms>写字,笔顺</match_terms>
      <apply_palette>writing_warm_brown</apply_palette>
    </rule>

    <rule priority="78">
      <match_terms>儿歌,童谣</match_terms>
      <apply_palette>playful_coral</apply_palette>
    </rule>

    <rule priority="1">
      <apply_palette>default_yuwen_balanced</apply_palette>
    </rule>

  </palette_routing>

  <palette_color_bias>

    <palette id="lower_grade_core">
      <color_bias>整体色调可轻微偏向明亮天空蓝与柔和暖黄，保持高明度与轻快感</color_bias>
    </palette>

    <palette id="writing_warm_brown">
      <color_bias>整体色调可轻微偏向米色与温暖棕色，降低饱和度，呈现纸张质感</color_bias>
    </palette>

    <palette id="playful_coral">
      <color_bias>整体色调可轻微偏向珊瑚粉与浅蓝，对比柔和但保持活泼感</color_bias>
    </palette>

    <palette id="forest_green">
      <color_bias>整体色调可轻微偏向清新绿色，明度适中，避免过深或过暗</color_bias>
    </palette>

    <palette id="pond_blue">
      <color_bias>整体色调可轻微偏向清透蓝色与浅青绿，增加通透感与轻盈感</color_bias>
    </palette>

    <palette id="autumn_ochre">
      <color_bias>整体色调可轻微偏向暖赭色与柔和金色，营造温暖但不过重的色彩氛围</color_bias>
    </palette>

    <palette id="winter_cool_blue">
      <color_bias>整体色调可轻微偏向低饱和冷蓝与浅灰蓝，保持清淡与安静</color_bias>
    </palette>

    <palette id="dreamy_purple_blue">
      <color_bias>整体色调可轻微偏向紫蓝色与淡紫光感，饱和度适中偏柔和</color_bias>
    </palette>

    <palette id="fable_red_brown">
      <color_bias>整体色调可轻微偏向红棕与米色，色彩温和不过分鲜艳</color_bias>
    </palette>

    <palette id="classical_qingdai">
      <color_bias>整体色调可轻微偏向青黛灰绿，降低对比度，保持克制与留白感</color_bias>
    </palette>

    <palette id="bamboo_ink_green">
      <color_bias>整体色调可轻微偏向墨绿与灰绿，饱和度偏低，呈现沉静气质</color_bias>
    </palette>

    <palette id="vermilion_gold">
      <color_bias>整体色调可轻微偏向朱红与米金，红色控制在点缀级别不过度铺满</color_bias>
    </palette>

    <palette id="literary_blue_gray">
      <color_bias>整体色调可轻微偏向蓝灰与中性色，降低饱和度以提升阅读舒适度</color_bias>
    </palette>

    <palette id="homeland_red_blue">
      <color_bias>整体色调可轻微偏向深红与沉稳蓝，控制对比，保持庄重感</color_bias>
    </palette>

    <palette id="knowledge_blue_green">
      <color_bias>整体色调可轻微偏向蓝绿与白色，保持清晰、干净与结构感</color_bias>
    </palette>

    <palette id="math_blue_orange">
      <color_bias>整体色调可轻微偏向清爽蓝色，辅以少量橙色强调重点</color_bias>
    </palette>

    <palette id="math_deep_blue">
      <color_bias>整体色调可轻微偏向深蓝与灰色，增强理性与结构感，避免高饱和</color_bias>
    </palette>

    <palette id="physics_dark_teal">
      <color_bias>整体色调可轻微偏向冷青色与深蓝，辅以少量亮色点缀增强科技感</color_bias>
    </palette>

    <palette id="default_yuwen_balanced">
      <color_bias>整体色调保持中性平衡，可略微偏向浅蓝与柔和暖色，避免明显色彩倾向</color_bias>
    </palette>

  </palette_color_bias>

</visual>

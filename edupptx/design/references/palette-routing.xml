    <rule priority="108">
      <match_terms>冰雪,雪景,雪花,下雪,冬天,寒冬,梅花,冰面,冰晶</match_terms>
      <apply_palette>winter_cool_blue</apply_palette>
    </rule>

    <rule priority="106">

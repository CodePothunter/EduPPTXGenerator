{
  "meta": {
    "schema_version": "0.1",
    "name": "emerald",
    "description": "Fresh green theme for nature, growth, and science topics"
  },

  "global": {
    "palette": {
      "primary": "#1F2937",
      "accent": "#059669",
      "accent_light": "#D1FAE5",
      "bg": "#F0FDF4",
      "text": "#1F2937",
      "text_secondary": "#4B5563",
      "card_fill": "#FFFFFF",
      "shadow": "#6EE7B7",
      "icon": "#059669"
    },
    "fonts": {
      "heading": {"family": "Noto Sans SC", "fallback": "Arial"},
      "body": {"family": "Noto Sans SC", "fallback": "Arial"}
    },
    "background": {
      "type": "diagonal_gradient",
      "seed_extra": ""
    }
  },

  "semantic": {
    "title_size_pt": 38,
    "subtitle_size_pt": 20,
    "body_size_pt": 12,
    "card_title_size_pt": 16,
    "footer_size_pt": 13,
    "formula_size_pt": 18,

    "heading_color": "palette.text",
    "body_color": "palette.text_secondary",
    "accent_color": "palette.accent",
    "card_fill_color": "palette.card_fill",
    "card_title_color": "palette.accent",
    "icon_color": "palette.icon",

    "bg_overlay_color": "palette.bg",
    "bg_overlay_alpha": 0.55,

    "card_corner_radius": 8000,
    "card_shadow": {
      "blur_pt": 30,
      "dist_pt": 8,
      "color": "palette.shadow",
      "alpha_pct": 14
    }
  },

  "layout": {
    "margin": "comfortable",
    "card_spacing": "normal",
    "icon_size": "large",
    "title_position": "top_left",
    "content_density": "standard"
  },

  "decorations": {
    "title_underline": true,
    "content_panel": true,
    "panel_alpha_pct": 35,
    "footer_separator": true,
    "quote_bar": true,
    "section_diamond": true,
    "closing_circle": true
  },

  "slide_overrides": {}
}

# ── 文本生成 LLM ─────────────────────────────────
# 火山方舟 (豆包) 或任何 OpenAI 兼容 API
GEN_MODEL=your-model-endpoint
GEN_APIKEY=your-api-key
# GEN_BASE_URL=https://ark.cn-beijing.volces.com/api/v3  # 默认值，可不设

# Provider-specific 推理控制（可选，不填则用 provider 默认）
# DeepSeek: GEN_THINKING=enabled / GEN_REASONING_EFFORT=high
# OpenAI o-series: GEN_REASONING_EFFORT=low|medium|high
# 豆包: 默认 disabled（结构化输出场景）— 自动检测 volces.com，设 GEN_THINKING=enabled 可显式开启
# GEN_THINKING=
# GEN_REASONING_EFFORT=

# API 模式: "chat" = Chat Completions | "responses" = Responses API
# Responses API 支持联网搜索、上下文缓存等高级特性
LLM_PROVIDER=chat
# LLM 并行请求数 (SVG 生成 + Review，默认 4)
# LLM_CONCURRENCY=4
# Phase 2 material pages processed in parallel (default 3)
# EDUPPTX_MATERIALS_CONCURRENCY=3

# ── 图片生成 AI ──────────────────────────────────
# Seedream (火山方舟) 或 DALL-E 兼容 API
VISION_GEN_MODEL=your-image-model-endpoint
VISION_GEN_APIKEY=your-image-api-key

# Vision-language model for AI image metadata verification/enrichment
# OpenAI-compatible Chat Completions endpoint; independent from VISION_GEN_*.
VLM_MODEL=your-vlm-model-endpoint
VLM_APIKEY=your-vlm-api-key
# VLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── 图片搜索（可选）────────────────────────────────
# PIXABAY_API_KEY=your-pixabay-key
# UNSPLASH_ACCESS_KEY=your-unsplash-key

# ── 联网搜索（可选）────────────────────────────────
# Tavily 搜索 API (用于 --research 模式)
# TAVILY_API_KEY=your-tavily-key

# ── 视觉规划器格式（可选）──────────────────────────
# 视觉规划器输出格式（可选）：json (默认，旧路径) | design_md (新 8 段 DESIGN.md 路径)
# EDUPPTX_VISUAL_PLANNER_FORMAT=json
# 风格 lint 严格模式（设为 1 时 contrast warning 升级为 error）
# EDUPPTX_LINT_STRICT=0

# ── AI 图片素材复用库（可选）──────────────────────
# 总开关：设为 1 时完全关闭复用读路径，回到"每次都新生成"的 master 行为
# （同时跳过 caption/keyword 等复用专用 LLM 调用）。默认开启复用。
# EDUPPTX_DISABLE_AI_IMAGE_REUSE=0
# 复用库存储后端（Phase B2）：json（默认，split index + npz）| sqlite（library.db）。
# sqlite 需先 `edupptx assets migrate <库目录>` 生成 library.db；切默认前应做 goldset A/B。
# EDUPPTX_REUSE_BACKEND=json
# 主素材库目录（v2 起即有，默认 ./materials_library）
# LIBRARY_DIR=./materials_library
# 复用检索的库目录列表（逗号或 os.pathsep 分隔的绝对路径）。
# 留空时默认 = [LIBRARY_DIR, ./materials_library_ppt]（相对当前工作目录，建议显式设绝对路径）
# REUSE_LIBRARY_DIRS=/abs/path/materials_library_ppt
# 复用嵌入模型。离线服务器请用本机绝对路径（如 /opt/models/Qwen3-Embedding-0.6B）
# EDUPPTX_AI_IMAGE_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# 关闭嵌入召回（仅 BM25+substring，policy_score 会按可用权重归一化）
# EDUPPTX_DISABLE_AI_IMAGE_EMBEDDINGS=0
# 建库时嵌入编码 batch 大小（默认见 DEFAULT_EMBEDDING_BATCH_SIZE）
# EDUPPTX_AI_IMAGE_EMBEDDING_BUILD_BATCH_SIZE=
# 复用 LLM/字段生成全局并发上限（留空=不额外限制）
# EDUPPTX_LLM_MAX_WORKERS=
# 跨会话复用覆盖缺口日志路径（默认写到当前目录下的覆盖日志文件）
# EDUPPTX_REUSE_COVERAGE_LOG=
# 复用 debug 模式（生成 ai_image_reuse_debug.json 等产物，配合 --debug）
# EDUPPTX_AI_IMAGE_REUSE_DEBUG_MODE=

# ── 素材库后台入库（可选）──────────────────────────
# 入库默认后台运行；一次性 debug 运行不想写库时用 CLI 的 --no-asset-ingest。
# 入库时是否对资产跑 VLM 审查（默认关闭，VLM 路径尚未充分调试）
# EDUPPTX_ASSET_LIBRARY_VLM_REVIEW=0
# 入库 SQLite 队列 DB 路径（默认在库目录下自动生成）
# EDUPPTX_ASSET_INGEST_JOB_DB=

# ── 练习题库绑定（可选，默认关闭）──────────────────
# EDUPPTX_EXERCISE_POLICY=0
# EDUPPTX_EXERCISE_BANK_PATH=        # JSON 题库路径
# EDUPPTX_EXERCISE_DB_PATH=          # teach-kb SQLite 路径
# EDUPPTX_EXERCISE_IMAGE_ROOT=       # 题图根目录
# EDUPPTX_EXERCISE_CANDIDATE_LIMIT=4 # 每类候选题上限

# ── 复用匹配并发/批量（可选）──────────────────────
# 复用匹配字段生成：每次 1 张 + 15 并行（准确性优先），可调
# EDUPPTX_REUSE_TARGET_KEYWORD_BATCH_SIZE=1
# EDUPPTX_REUSE_TARGET_KEYWORD_WORKERS=15
# 复用 policy/LLM-review 跨图外层并发
# EDUPPTX_REUSE_POLICY_WORKERS=5
# EDUPPTX_REUSE_EMBED_RESCUE_FLOOR=0.70  # 复用召回嵌入救援地板，默认 0.70
